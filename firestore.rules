
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "mdbUrj0LoqQGL2EABx7pdUvnaJm2" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false; 
    }

    match /orders/{orderId} {
      // Admins têm acesso total (inclusive list e update)
      allow get, list, update, delete: if isAdmin();
      
      // Clientes podem criar pedidos e admins também
      allow create: if isAdmin() || (request.resource.data.id == orderId);

      match /items/{itemId} {
        allow get, list, update, delete: if isAdmin();
        allow create: if isAdmin() || (request.resource.data.orderId == orderId);
      }
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
