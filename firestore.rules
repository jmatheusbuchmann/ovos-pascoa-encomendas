rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Verifica se o usuário é administrador.
     * Adicionei o seu UID específico (do erro) como administrador mestre para facilitar seu primeiro acesso.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "mdbUrj0LoqQGL2EABx7pdUvnaJm2" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow list, create, update, delete: if false; 
    }

    match /orders/{orderId} {
      // Apenas admins podem listar ou ver detalhes de qualquer pedido
      allow get, list: if isAdmin();
      
      // CLIENTES podem criar pedidos (necessário para o formulário funcionar)
      // Validamos se o ID no documento coincide com o ID da rota
      allow create: if request.resource.data.id == orderId;
      
      // Apenas admins podem atualizar (mudar status) ou deletar pedidos
      allow update, delete: if isAdmin();

      // Regras para os itens dentro do pedido
      match /items/{itemId} {
        allow get, list: if isAdmin();
        allow create: if request.resource.data.orderId == orderId;
        allow update, delete: if isAdmin();
      }
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}