
{
  "entities": {
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a customer's order for Easter eggs, including customer details, payment, delivery/pickup preferences, and overall status.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order entity."
        },
        "customerName": {
          "type": "string",
          "description": "The full name of the customer."
        },
        "customerWhatsapp": {
          "type": "string",
          "description": "The WhatsApp contact number of the customer."
        },
        "orderDate": {
          "type": "string",
          "description": "The date and time when the order was placed.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Order status.",
          "enum": ["pendente", "confirmado", "pronto", "entregue", "cancelado"]
        },
        "paymentMethod": {
          "type": "string",
          "description": "Chosen payment method.",
          "enum": ["pix", "cartao"]
        },
        "paymentStatus": {
          "type": "string",
          "description": "Payment status of the order.",
          "enum": ["pendente", "pago", "parcial"]
        },
        "amountPaid": {
          "type": "number",
          "description": "Amount already paid by the customer."
        },
        "receivingMethod": {
          "type": "string",
          "description": "Receiving method.",
          "enum": ["retirada", "entrega"]
        },
        "pickupDate": {
          "type": "string",
          "format": "date"
        },
        "pickupTime": {
          "type": "string"
        },
        "deliveryZipCode": {
          "type": "string"
        },
        "deliveryFee": {
          "type": "number"
        },
        "customerNotes": {
          "type": "string"
        },
        "estimatedTotalAmount": {
          "type": "number"
        },
        "isManuallyAdded": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "customerName",
        "customerWhatsapp",
        "orderDate",
        "status",
        "paymentStatus"
      ]
    },
    "OrderItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderItem",
      "type": "object",
      "description": "A specific item within an order.",
      "properties": {
        "id": {
          "type": "string"
        },
        "orderId": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "characterTheme": {
          "type": "string"
        },
        "drawingType": {
          "type": "string",
          "enum": ["normal", "personalizado"]
        },
        "childNameForDrawing": {
          "type": "string"
        },
        "unitPrice": {
          "type": "number"
        },
        "itemTotal": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "orderId",
        "quantity",
        "characterTheme",
        "drawingType",
        "unitPrice",
        "itemTotal"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": "object",
      "description": "Identifies admin users."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Main order documents."
    },
    "/orders/{orderId}/items/{itemId}": {
      "schema": { "$ref": "#/backend/entities/OrderItem" },
      "description": "Items associated with an order."
    }
  }
}
